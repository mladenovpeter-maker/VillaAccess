# Copy this file to .env and fill in your values
# NEVER commit .env to git

# PostgreSQL
POSTGRES_PASSWORD=your_strong_password_here

# JWT Secret — generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# Hikvision cameras
HIKVISION_ADMIN_USER=admin
HIKVISION_ADMIN_PASSWORD=your_camera_password

# AI thresholds (0-100)
AI_CONFIDENCE_HIGH=90
AI_CONFIDENCE_MEDIUM=70

# Node.js API (for Replit dev)
DATABASE_URL=postgresql://user:password@localhost:5432/villa_access
NODE_ENV=development
