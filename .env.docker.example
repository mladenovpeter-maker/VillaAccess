# Copy this file to .env.docker and fill in real values before running.
#
#   cp .env.docker.example .env.docker
#   docker compose --env-file .env.docker up --build

# ── Required secrets ─────────────────────────────────────────────────────────

# PostgreSQL password — choose a strong value
POSTGRES_PASSWORD=change_me_strong_password

# JWT signing secret — must be at least 32 random characters
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_at_least_32_random_characters_here

# Shared secret between the backend and the ai-worker (ANPR pipeline).
# Generate with: openssl rand -hex 32
# Both `backend` and `ai-worker` must see the same value.
ANPR_WORKER_TOKEN=change_me_at_least_32_random_characters_here

# Optional — EasyOCR languages and how often the worker refreshes its
# camera target list from the backend.
ANPR_LANGUAGES=en
ANPR_REFRESH_TARGETS_SECONDS=30

# ── AI fallback (opt-in, default OFF) ────────────────────────────────────────
# After 3 denied detections on the same gate camera within 10 minutes,
# send the snapshots to OpenAI gpt-4o-mini vision to re-read the plate.
# If AI is confident (>=70) AND the plate matches a registered vehicle
# with an active reservation, open the gate via the existing adapter.
# Cost: ~$0.01-0.03 per AI call. Vehicles are never auto-created.
#
# Leave both empty / commented out to keep the feature disabled (no AI
# calls, no extra HTTP load on cameras, zero behavioural change).
OPENAI_API_KEY=
AI_FALLBACK_ENABLED=false

# ── Tuya smart-lock integration (Phase 1: read-only) ─────────────────────────
# Each villa has one Wi-Fi smart lock (Tuya ecosystem). The backend talks to
# Tuya OpenAPI via these credentials. Get them from:
#   iot.tuya.com → Cloud → Development → your project → Overview
# All locks in the project share the same credentials — they are NOT per-lock.
#
# TUYA_REGION:
#   eu  — Central Europe data center  (default; most likely correct for BG)
#   us  — Western America data center
#   in  — India data center
#   cn  — China data center
#
# Leave all three empty / commented out to keep Tuya disabled. The smart_locks
# table will still exist, but /api/locks/:id/status and /api/locks/:id/events
# will return 503 "Tuya not configured" instead of calling the cloud.
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=
TUYA_REGION=eu
