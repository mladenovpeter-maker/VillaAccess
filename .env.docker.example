# Copy this file to .env.docker and fill in real values before running.
#
#   cp .env.docker.example .env.docker
#   docker compose --env-file .env.docker up --build

# ── Required secrets ─────────────────────────────────────────────────────────

# PostgreSQL password — choose a strong value
POSTGRES_PASSWORD=change_me_strong_password

# JWT signing secret — must be at least 32 random characters
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_at_least_32_random_characters_here

# Shared secret between the backend and the ai-worker (ANPR pipeline).
# Generate with: openssl rand -hex 32
# Both `backend` and `ai-worker` must see the same value.
ANPR_WORKER_TOKEN=change_me_at_least_32_random_characters_here

# Optional — EasyOCR languages and how often the worker refreshes its
# camera target list from the backend.
ANPR_LANGUAGES=en
ANPR_REFRESH_TARGETS_SECONDS=30
